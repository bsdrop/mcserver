         double n0;
         if (t0 < 0.0) {
             n0 = 0.0;
diff --git a/net/minecraft/world/level/pathfinder/BinaryHeap.java b/net/minecraft/world/level/pathfinder/BinaryHeap.java
index 2cb6d1322e44a683e790f9ff4d989aea3b9472b1..e9ee55c5da80bd1a7c2837010435dba852c33678 100644
