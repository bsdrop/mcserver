+        // Canvas - FMA: fma(g0,x, fma(g1,y, g2*z)) → 2 FMA + 1 mul vs 3 mul + 2 add
+        return Math.fma(g[0], x, Math.fma(g[1], y, g[2] * z));
     }
 
