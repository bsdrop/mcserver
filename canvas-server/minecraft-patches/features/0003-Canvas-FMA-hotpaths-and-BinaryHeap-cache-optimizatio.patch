-        return var120 + (var103 * (var121 - var120));
-        // Canvas end - inline math & small optimization: remove frequent type conversions and redundant ops
+        // Canvas start - FMA: replace a*b+c patterns with fused multiply-add (1 rounding error vs 2, 1 insn on ARM NEON/x86 FMA)
+        // Dot products: g[0]*x + g[1]*y + g[2]*z → fma(g[0],x, fma(g[1],y, g[2]*z))
+        final double var87 = Math.fma(FLAT_SIMPLEX_GRAD[var20],     xr,   Math.fma(FLAT_SIMPLEX_GRAD[var20 | 1], yr,   FLAT_SIMPLEX_GRAD[var20 | 2] * zr));
+        final double var88 = Math.fma(FLAT_SIMPLEX_GRAD[var21],     var60, Math.fma(FLAT_SIMPLEX_GRAD[var21 | 1], yr,   FLAT_SIMPLEX_GRAD[var21 | 2] * zr));
+        final double var89 = Math.fma(FLAT_SIMPLEX_GRAD[var22],     xr,   Math.fma(FLAT_SIMPLEX_GRAD[var22 | 1], var61, FLAT_SIMPLEX_GRAD[var22 | 2] * zr));
+        final double var90 = Math.fma(FLAT_SIMPLEX_GRAD[var23],     var60, Math.fma(FLAT_SIMPLEX_GRAD[var23 | 1], var61, FLAT_SIMPLEX_GRAD[var23 | 2] * zr));
+        final double var91 = Math.fma(FLAT_SIMPLEX_GRAD[var24],     xr,   Math.fma(FLAT_SIMPLEX_GRAD[var24 | 1], yr,   FLAT_SIMPLEX_GRAD[var24 | 2] * var62));
+        final double var92 = Math.fma(FLAT_SIMPLEX_GRAD[var25],     var60, Math.fma(FLAT_SIMPLEX_GRAD[var25 | 1], yr,   FLAT_SIMPLEX_GRAD[var25 | 2] * var62));
+        final double var93 = Math.fma(FLAT_SIMPLEX_GRAD[var26],     xr,   Math.fma(FLAT_SIMPLEX_GRAD[var26 | 1], var61, FLAT_SIMPLEX_GRAD[var26 | 2] * var62));
+        final double var94 = Math.fma(FLAT_SIMPLEX_GRAD[var27],     var60, Math.fma(FLAT_SIMPLEX_GRAD[var27 | 1], var61, FLAT_SIMPLEX_GRAD[var27 | 2] * var62));
+
+        // Smoothstep: t^3*(6t^2 - 15t + 10) = t^3*((6t - 15)t + 10)
+        // FMA chain reduces 3 mul+2 add → 2 FMA per axis
+        final double var95  = Math.fma(xr,        6.0, -15.0);
+        final double var96  = Math.fma(yrOriginal, 6.0, -15.0);
+        final double var97  = Math.fma(zr,         6.0, -15.0);
+        final double var98  = Math.fma(xr,        var95,  10.0);
+        final double var99  = Math.fma(yrOriginal, var96,  10.0);
+        final double var100 = Math.fma(zr,         var97,  10.0);
+        final double xr2    = xr * xr;
+        final double yr2    = yrOriginal * yrOriginal;
+        final double zr2    = zr * zr;
+        final double var101 = xr2 * xr * var98;
+        final double var102 = yr2 * yrOriginal * var99;
+        final double var103 = zr2 * zr * var100;
+
+        // Trilinear lerp chain: lerp(t, a, b) = fma(t, b-a, a)
+        final double var113 = Math.fma(var101, var88 - var87, var87);
+        final double var114 = Math.fma(var101, var94 - var93, var93);
+        final double var115 = Math.fma(var101, var92 - var91, var91);
+        final double var116 = Math.fma(var101, var90 - var89, var89);
+        final double var120 = Math.fma(var102, var116 - var113, var113);
+        final double var121 = Math.fma(var102, var114 - var115, var115);
+        return Math.fma(var103, var121 - var120, var120);
+        // Canvas end - FMA
     }
 
     private double sampleWithDerivative(final int x, final int y, final int z, final double xr, final double yr, final double zr, final double[] derivativeOut) {
