@@ -4,6 +4,11 @@ import java.util.Arrays;
 
 public class BinaryHeap {
     private Node[] heap = new Node[128];
+    // Canvas - parallel float array: heap comparisons read costs[] directly without
+    // dereferencing Node pointers, eliminating cache misses in the tight heap loops.
+    // On Cortex-A72 (RPi 4), a pointer chase costs ~40 cycles; this makes upHeap/downHeap
+    // work only on a contiguous float[] until the swap is decided.
+    private float[] costs = new float[128];
     private int size;
 
     public Node insert(final Node node) {
@@ -12,12 +17,17 @@ public class BinaryHeap {
         }
 
         if (this.size == this.heap.length) {
-            Node[] newHeap = new Node[this.size << 1];
+            final int newLen = this.size << 1;
+            final Node[] newHeap = new Node[newLen];
+            final float[] newCosts = new float[newLen];
             System.arraycopy(this.heap, 0, newHeap, 0, this.size);
+            System.arraycopy(this.costs, 0, newCosts, 0, this.size);
             this.heap = newHeap;
+            this.costs = newCosts;
         }
 
         this.heap[this.size] = node;
+        this.costs[this.size] = node.f;
         node.heapIdx = this.size;
         this.upHeap(this.size++);
         return node;
@@ -32,34 +42,43 @@ public class BinaryHeap {
     }
 
     public Node pop() {
-        Node popped = this.heap[0];
-        this.heap[0] = this.heap[--this.size];
-        this.heap[this.size] = null;
-        if (this.size > 0) {
+        final Node popped = this.heap[0];
+        final int last = --this.size;
+        if (last > 0) {
+            final Node moved = this.heap[last];
+            this.heap[0] = moved;
+            this.costs[0] = this.costs[last];
