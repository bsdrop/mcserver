+    // ─── Root emitter ────────────────────────────────────────────────────────────
+
+    private void emitRoot(DensityFunction df) {
+        if (df instanceof DensityFunctions.CanvasFindTopSurfaceDF fts) {
+            String densityFn  = emitDF(fts.canvas$ftsInnerDensity());
+            String upperBndFn = emitDF(fts.canvas$ftsUpperBound());
+            if (failReason != null) return;
+            int lb = fts.canvas$ftsLowerBound(), ch = fts.canvas$ftsCellHeight();
+            src.append("__kernel void compute_surface(\n");
+            src.append("    __global const int* positions,\n");
+            src.append("    __global int* results,\n");
+            src.append("    const int N\n) {\n");
+            src.append("    int id = get_global_id(0);\n");
+            src.append("    if (id >= N) return;\n");
+            src.append("    double bx = (double)positions[id*2  ];\n");
+            src.append("    double bz = (double)positions[id*2+1];\n");
+            // upperBound at Y=0 (typically Y-independent spline)
+            src.append("    double topYf = ").append(cY(upperBndFn, "0.0")).append(";\n");
+            src.append("    int topY = (int)floor(topYf / ").append(ch).append(".0) * ").append(ch).append(";\n");
+            src.append("    if (topY <= ").append(lb).append(") { results[id] = ").append(lb).append("; return; }\n");
+            src.append("    int result = ").append(lb).append(";\n");
+            src.append("    for (int blockY = topY; blockY >= ").append(lb)
+               .append("; blockY -= ").append(ch).append(") {\n");
+            src.append("        if (").append(cY(densityFn, "(double)blockY")).append(" > 0.0) {\n");
+            src.append("            result = blockY; break;\n        }\n    }\n");
+            src.append("    results[id] = result;\n}\n");
+        } else {
+            String rootFn = emitDF(df);
+            if (failReason != null) return;
+            src.append("""
+                __kernel void compute_surface(
+                    __global const int* positions,
+                    __global int* results,
+                    const int N
+                ) {
+                    int id = get_global_id(0);
+                    if (id >= N) return;
+                    double bx = (double)positions[id*2  ];
+                    double bz = (double)positions[id*2+1];
+                """);
+            src.append("    results[id] = (int)floor(").append(cY(rootFn, "0.0")).append(");\n}\n");
+        }
+    }
+
+    // ─── DF tree walker ──────────────────────────────────────────────────────────
+
+    /**
+     * Emits code for a DensityFunction node (deduplicated by identity).
+     * Returns the FUNCTION NAME only (e.g. "df_3"), not a call expression.
+     * Use c3(fn) or cY(fn, y) to produce call expressions.
+     */
+    private String emitDF(DensityFunction df) {
+        if (failReason != null) return "df_err";
+
+        df = unwrap(df);
+
+        if (ids.containsKey(df)) return "df_" + ids.getInt(df);
+        int id = counter++;
+        ids.put(df, id);
+        String fn = "df_" + id;
+
+        String cn = df.getClass().getSimpleName();
+
+        // Private types detected by class name
+        switch (cn) {
+            case "Constant" -> { emitConstantFn(fn, df.compute(ZERO_CTX)); return fn; }
+            case "BlendAlpha" -> { emitConstantFn(fn, 1.0); return fn; }
+            case "BlendOffset" -> { emitConstantFn(fn, 0.0); return fn; }
+            case "BeardifierMarker" -> { emitConstantFn(fn, 0.0); return fn; }
+        }
+
+        // Public/protected/interface dispatch
+        int srcLenBefore = src.length();
+        if (df instanceof DensityFunctions.CanvasYClampedGradientDF y) {
+            emitYClampedGradient(fn, y);
+        } else if (df instanceof DensityFunctions.CanvasRangeChoiceDF r) {
+            emitRangeChoice(fn, r);
+        } else if (df instanceof DensityFunctions.CanvasFindTopSurfaceDF fts) {
+            emitFindTopSurfaceInner(fn, fts);
+        } else if (df instanceof DensityFunctions.TwoArgumentSimpleFunction t) {
+            emitTwoArg(fn, t);
+        } else if (df instanceof DensityFunctions.Spline sp) {
+            emitSpline(fn, sp);
+        } else if (df instanceof DensityFunctions.ShiftedNoise sn) {
+            emitShiftedNoise(fn, sn);
+        } else if (df instanceof DensityFunctions.Shift s) {
+            emitShiftFull(fn, s.offsetNoise());
+        } else if (df instanceof DensityFunctions.ShiftA s) {
+            emitShiftFixed(fn, s.offsetNoise(), 0.0);
+        } else if (df instanceof DensityFunctions.ShiftB s) {
+            emitShiftB(fn, s.offsetNoise());
+        } else if (df instanceof DensityFunctions.Noise n) {
+            emitNoise(fn, n);
+        } else if (df instanceof BlendedNoise bn) {
+            emitBlendedNoise(fn, bn);
+        } else if (df instanceof DensityFunctions.IntervalSelect is) {
+            emitIntervalSelect(fn, is);
+        } else if (df instanceof DensityFunctions.Clamp cl) {
+            String inner = c3(emitDF(cl.input()));
+            src.append("double ").append(fn)
+               .append("(double bx, double blockY, double bz) { return mc_clamp(")
+               .append(inner).append(", ").append(hexD(cl.minValue()))
+               .append(", ").append(hexD(cl.maxValue())).append("); }\n");
+        } else if (df instanceof DensityFunctions.Mapped m) {
+            emitMapped(fn, m);
+        } else {
+            failReason = "unsupported node: " + df.getClass().getName();
+        }
+
+        // Guard: if emitter wrote nothing (e.g., set failReason and returned),
+        // emit a stub so the CL source is syntactically valid.
+        // failReason is checked by compile() — this stub will never be used in practice.
+        if (src.length() == srcLenBefore) {
+            LOGGER.warn("[CanvasGPU] emitDF wrote no body for id={} class={} failReason={}",
+                id, df.getClass().getName(), failReason);
+            src.append("double ").append(fn)
+               .append("(double bx, double blockY, double bz) { return 0.0; /* stub: ")
+               .append(df.getClass().getSimpleName()).append(" */}\n");
+        }
+
+        return fn;
+    }
+
+    private DensityFunction unwrap(DensityFunction df) {
+        while (true) {
+            if (df instanceof DensityFunctions.HolderHolder hh) { df = hh.function().value(); continue; }
+            if (df instanceof DensityFunctions.MarkerOrMarked m) { df = m.wrapped(); continue; }
+            break;
+        }
+        return df;
+    }
+
+    // ─── Node emitters ────────────────────────────────────────────────────────────
+
+    private void emitConstantFn(String fn, double val) {
+        src.append("double ").append(fn)
+           .append("(double bx, double blockY, double bz) { return ").append(hexD(val)).append("; }\n");
+    }
+
+    private void emitYClampedGradient(String fn, DensityFunctions.CanvasYClampedGradientDF y) {
+        double fromY = y.canvas$ycgFromY(), toY = y.canvas$ycgToY();
+        double fromV = y.canvas$ycgFromValue(), toV = y.canvas$ycgToValue();
+        // Java: Mth.clampedMap(blockY, fromY, toY, fromV, toV)
+        //     = clampedLerp(inverseLerp(blockY,fromY,toY), fromV, toV)
+        //     inverseLerp=(v-fromY)/(toY-fromY); clampedLerp=f<0?fromV:(f>1?toV:lerp)
+        src.append("double ").append(fn).append("(double bx, double blockY, double bz) {\n");
+        src.append("    double f = (blockY - ").append(hexD(fromY)).append(") / ")
+           .append(hexD(toY - fromY)).append(";\n");
+        src.append("    return f<0.0 ? ").append(hexD(fromV)).append(" : (f>1.0 ? ").append(hexD(toV))
+           .append(" : (").append(hexD(fromV)).append(" + f*(").append(hexD(toV)).append(" - ").append(hexD(fromV)).append(")));\n}\n");
+    }
+
+    private void emitNoise(String fn, DensityFunctions.Noise n) {
+        NormalNoise nn = asNormalNoise(n.noise());
+        if (nn == null) { failReason = "Noise: NormalNoise not initialized"; return; }
+        String evalFn = emitNormalNoiseConsts("nn_" + fn, nn);
+        double xzSc = n.xzScale(), ySc = n.yScale();
+        src.append("double ").append(fn).append("(double bx, double blockY, double bz) {\n")
+           .append("    return eval_nn_").append(evalFn)
+           .append("(bx*").append(hexD(xzSc)).append(", blockY*").append(hexD(ySc))
+           .append(", bz*").append(hexD(xzSc)).append(");\n}\n");
+    }
+
+    private void emitShiftedNoise(String fn, DensityFunctions.ShiftedNoise sn) {
+        NormalNoise nn = asNormalNoise(sn.noise());
+        if (nn == null) { failReason = "ShiftedNoise: NormalNoise not initialized"; return; }
+        String shiftX = c3(emitDF(sn.shiftX()));
+        String shiftY = c3(emitDF(sn.shiftY()));
+        String shiftZ = c3(emitDF(sn.shiftZ()));
+        String evalFn = emitNormalNoiseConsts("nn_" + fn, nn);
+        double xzSc = sn.xzScale(), ySc = sn.yScale();
+        src.append("double ").append(fn).append("(double bx, double blockY, double bz) {\n")
+           .append("    double sx=").append(shiftX).append("; double sy=").append(shiftY)
+           .append("; double sz=").append(shiftZ).append(";\n")
+           .append("    return eval_nn_").append(evalFn)
+           .append("(bx*").append(hexD(xzSc)).append("+sx, blockY*").append(hexD(ySc))
+           .append("+sy, bz*").append(hexD(xzSc)).append("+sz);\n}\n");
+    }
+
+    private void emitShiftFull(String fn, DensityFunction.NoiseHolder holder) {
+        NormalNoise nn = asNormalNoise(holder);
+        if (nn == null) { failReason = "Shift: NormalNoise not initialized"; return; }
+        String evalFn = emitNormalNoiseConsts("nn_" + fn, nn);
+        src.append("double ").append(fn).append("(double bx, double blockY, double bz) {\n")
+           .append("    return eval_nn_").append(evalFn)
+           .append("(bx*0.25, blockY*0.25, bz*0.25)*4.0;\n}\n");
+    }
+
+    private void emitShiftFixed(String fn, DensityFunction.NoiseHolder holder, double fixedY) {
+        NormalNoise nn = asNormalNoise(holder);
+        if (nn == null) { failReason = "ShiftA: NormalNoise not initialized"; return; }
+        String evalFn = emitNormalNoiseConsts("nn_" + fn, nn);
+        src.append("double ").append(fn).append("(double bx, double blockY, double bz) {\n")
+           .append("    return eval_nn_").append(evalFn)
+           .append("(bx*0.25, ").append(hexD(fixedY)).append(", bz*0.25)*4.0;\n}\n");
+    }
+
+    private void emitShiftB(String fn, DensityFunction.NoiseHolder holder) {
+        NormalNoise nn = asNormalNoise(holder);
+        if (nn == null) { failReason = "ShiftB: NormalNoise not initialized"; return; }
+        String evalFn = emitNormalNoiseConsts("nn_" + fn, nn);
+        src.append("double ").append(fn).append("(double bx, double blockY, double bz) {\n")
+           .append("    return eval_nn_").append(evalFn)
+           .append("(bz*0.25, bx*0.25, 0.0)*4.0;\n}\n");
+    }
+
+    private void emitTwoArg(String fn, DensityFunctions.TwoArgumentSimpleFunction t) {
+        String a1 = c3(emitDF(t.argument1()));
+        String a2 = c3(emitDF(t.argument2()));
+        // Java: ADD=v1+arg2; MUL=v1==0?0:v1*arg2 (short-circuit); MIN/MAX use Math.min/max
+        // (mc_min/mc_max match Math.min/max for finite; the static-bound short-circuit is value-equivalent).
+        String expr = switch (t.type()) {
+            case ADD -> "(" + a1 + " + " + a2 + ")";
+            case MUL -> "({ double _m1=" + a1 + "; _m1==0.0?0.0:_m1*(" + a2 + "); })";
+            case MIN -> "mc_min(" + a1 + ", " + a2 + ")";
+            case MAX -> "mc_max(" + a1 + ", " + a2 + ")";
+        };
+        if (t.type() == DensityFunctions.TwoArgumentSimpleFunction.Type.MUL) {
+            src.append("double ").append(fn)
+               .append("(double bx, double blockY, double bz) { double _m1=").append(a1)
+               .append("; return _m1==0.0?0.0:_m1*(").append(a2).append("); }\n");
+        } else {
+            src.append("double ").append(fn)
+               .append("(double bx, double blockY, double bz) { return ").append(expr).append("; }\n");
+        }
+    }
+
+    private void emitMapped(String fn, DensityFunctions.Mapped m) {
+        String inner = c3(emitDF(m.input()));
+        switch (m.type()) {
+            case ABS ->
+                src.append("double ").append(fn).append("(double bx, double blockY, double bz) { return fabs(").append(inner).append("); }\n");
+            case SQUARE ->
+                src.append("double ").append(fn).append("(double bx, double blockY, double bz) { double _v=").append(inner).append("; return _v*_v; }\n");
+            case CUBE ->
+                src.append("double ").append(fn).append("(double bx, double blockY, double bz) { double _v=").append(inner).append("; return _v*_v*_v; }\n");
+            case HALF_NEGATIVE ->
+                src.append("double ").append(fn).append("(double bx, double blockY, double bz) { double _v=").append(inner).append("; return _v<0.0?_v*0.5:_v; }\n");
+            case QUARTER_NEGATIVE ->
+                src.append("double ").append(fn).append("(double bx, double blockY, double bz) { double _v=").append(inner).append("; return _v<0.0?_v*0.25:_v; }\n");
+            case SQUEEZE -> {
+                String sqFn = "squeeze_" + fn;
+                // Java: c=Mth.clamp(t,-1,1); c/2.0 - c*c*c/24.0  (division, not *(1/24))
+                src.append("double ").append(sqFn).append("(double t) { double c=mc_clamp(t,-1.0,1.0); return c/2.0-c*c*c/24.0; }\n");
+                src.append("double ").append(fn).append("(double bx, double blockY, double bz) { return ").append(sqFn).append("(").append(inner).append("); }\n");
+            }
+            case INVERT -> // Java: 1.0 / input
+                src.append("double ").append(fn).append("(double bx, double blockY, double bz) { double _v=").append(inner).append("; return 1.0/_v; }\n");
+        }
+    }
+
+    private void emitIntervalSelect(String fn, DensityFunctions.IntervalSelect is) {
+        String inp = c3(emitDF(is.input()));
+        it.unimi.dsi.fastutil.doubles.DoubleList thr = is.thresholds();
+        java.util.List<DensityFunction> funcs = is.functions();
+        String[] fnames = new String[funcs.size()];
+        for (int i = 0; i < funcs.size(); i++) fnames[i] = c3(emitDF(funcs.get(i)));
+        if (failReason != null) return;
+        src.append("double ").append(fn).append("(double bx, double blockY, double bz) {\n");
+        src.append("    double _v=").append(inp).append(";\n");
+        for (int i = 0; i < thr.size(); i++) {
+            src.append("    if (_v < ").append(hexD(thr.getDouble(i))).append(") return ").append(fnames[i]).append(";\n");
+        }
+        src.append("    return ").append(fnames[funcs.size() - 1]).append(";\n}\n");
+    }
