+    private void emitSpline(String fn, DensityFunctions.Spline sp) {
+        String spFn = emitCubicSpline(sp.spline(), fn + "_cs");
+        src.append("double ").append(fn).append("(double bx, double blockY, double bz) { return (double)")
+           .append(c3(spFn)).append("; }\n");
+    }
+
+    private String emitCubicSpline(CubicSpline<DensityFunctions.Spline.Coordinate> cs, String prefix) {
+        return switch (cs) {
+            case CubicSpline.Constant<DensityFunctions.Spline.Coordinate> c -> {
+                String fn = prefix + "_k" + counter++;
+                src.append("float ").append(fn)
+                   .append("(double bx, double blockY, double bz) { return ").append(hexF(c.value())).append("f; }\n");
+                yield fn;
+            }
+            case CubicSpline.Multipoint<DensityFunctions.Spline.Coordinate> mp -> {
+                float[] locs   = mp.locations();
+                float[] derivs = mp.derivatives();
+                int K = locs.length;
+
+                List<String> valFns = new ArrayList<>(mp.values().size());
+                for (int i = 0; i < mp.values().size(); i++) {
+                    valFns.add(emitCubicSpline(mp.values().get(i), prefix + "_v" + i));
+                }
+                // coordinate function: emitDF returns name, wrap in c3()
+                String coordExpr = c3(emitDF(mp.coordinate().function()));
+
+                String fn = prefix + "_mp" + counter++;
+                src.append("float ").append(fn).append("(double bx, double blockY, double bz) {\n");
+                src.append("    float x = (float)(").append(coordExpr).append(");\n");
+
+                src.append("    const float locs[").append(K).append("] = {");
+                for (int i = 0; i < K; i++) { if (i>0) src.append(','); src.append(hexF(locs[i])).append('f'); }
+                src.append("};\n");
+                src.append("    const float derivs[").append(K).append("] = {");
+                for (int i = 0; i < K; i++) { if (i>0) src.append(','); src.append(hexF(derivs[i])).append('f'); }
+                src.append("};\n");
+
+                if (K == 1) {
+                    src.append("    float v0=").append(c3(valFns.get(0))).append(";\n");
+                    src.append("    return v0+derivs[0]*(x-locs[0]);\n}\n");
+                    yield fn;
+                }
+
+                src.append("    if (x<locs[0]) { float v=").append(c3(valFns.get(0)))
+                   .append("; return v+derivs[0]*(x-locs[0]); }\n");
+                src.append("    if (x>=locs[").append(K-1).append("]) { float v=")
+                   .append(c3(valFns.get(K-1))).append("; return v+derivs[").append(K-1)
+                   .append("]*(x-locs[").append(K-1).append("]); }\n");
+
+                src.append("    int idx=0;\n");
+                src.append("    while (idx<").append(K-2).append(" && x>=locs[idx+1]) idx++;\n");
+
+                src.append("    float y1,y2;\n    switch(idx){\n");
+                for (int i = 0; i < K-1; i++) {
+                    src.append("        case ").append(i).append(": y1=").append(c3(valFns.get(i)))
+                       .append("; y2=").append(c3(valFns.get(i+1))).append("; break;\n");
+                }
+                src.append("        default: y1=y2=0.0f;\n    }\n");
+
+                src.append("    float x1=locs[idx],x2=locs[idx+1];\n");
+                src.append("    float t=(x-x1)/(x2-x1);\n");
+                src.append("    float d1=derivs[idx],d2=derivs[idx+1];\n");
+                src.append("    float a=d1*(x2-x1)-(y2-y1);\n");
+                src.append("    float b=-d2*(x2-x1)+(y2-y1);\n");
+                src.append("    return y1+t*(y2-y1)+t*(1.0f-t)*(a+t*(b-a));\n}\n");
+
+                yield fn;
+            }
+            default -> throw new IllegalArgumentException("Unknown CubicSpline: " + cs.getClass());
+        };
+    }
+
+    // ─── NormalNoise emission ─────────────────────────────────────────────────────
+
+    /** Emits NormalNoise constants/eval function for nn under nnId.
+     *  If nn was already emitted under a different nnId, returns the canonical nnId
+     *  (dedup: no re-emission). Always returns the nnId of the eval_nn_ function to call. */
+    private String emitNormalNoiseConsts(String nnId, NormalNoise nn) {
+        String canonical = emittedNNIds.get(nn);
+        if (canonical != null) return canonical;  // reuse existing eval function
+        emittedNNIds.put(nn, nnId);
+
+        PerlinNoise first  = nn.canvas$getFirst();
+        PerlinNoise second = nn.canvas$getSecond();
+        double normFactor  = nn.canvas$getValueFactor();
+        double inputFactor = NormalNoise.canvas$getInputFactor();
+
+        double[] octA  = buildOctParams(first);
+        int[]    permA = buildPermBuffer(first);
+        double[] octB  = buildOctParams(second);
+        int[]    permB = buildPermBuffer(second);
+        int numA = octA.length / 6, numB = octB.length / 6;
+
+        emitDoubleArray(nnId + "_oct_a", octA);
+        emitIntArray(   nnId + "_perm_a", permA);
+        emitDoubleArray(nnId + "_oct_b", octB);
+        emitIntArray(   nnId + "_perm_b", permB);
+
+        // NormalNoise.getValue = (first(x,y,z) + second(x*F,y*F,z*F)) * valueFactor
+        String IF = hexD(inputFactor);
+        src.append("double eval_nn_").append(nnId).append("(double x, double y, double z) {\n");
+        emitPerlinLoop("va", nnId + "_oct_a", nnId + "_perm_a", numA, "x", "y", "z");
+        emitPerlinLoop("vb", nnId + "_oct_b", nnId + "_perm_b", numB,
+                       "x*" + IF, "y*" + IF, "z*" + IF);
+        src.append("    return (va+vb)*").append(hexD(normFactor)).append(";\n}\n");
+        return nnId;
+    }
+
+    // PerlinNoise.getValue: d += amp*g*vf over octaves, g=noise(wrap(c*factor)), exact order.
+    // BlendedNoise.compute — base 3D terrain noise (verified bit-exact in gpu_verify/blended_match.c)
+    private void emitBlendedNoise(String fn, BlendedNoise bn) {
+        emitBlendedTables(fn + "_main", bn.canvas$mainNoise(), 8);
+        emitBlendedTables(fn + "_min",  bn.canvas$minLimitNoise(), 16);
+        emitBlendedTables(fn + "_max",  bn.canvas$maxLimitNoise(), 16);
+        String xzMul = hexD(bn.canvas$xzMultiplier()), yMul = hexD(bn.canvas$yMultiplier());
+        String xzFac = hexD(bn.canvas$xzFactor()), yFac = hexD(bn.canvas$yFactor()), smear = hexD(bn.canvas$smearScaleMultiplier());
+        src.append("double ").append(fn).append("(double bx, double blockY, double bz) {\n");
+        src.append("    double limitX=bx*").append(xzMul).append(", limitY=blockY*").append(yMul).append(", limitZ=bz*").append(xzMul).append(";\n");
+        src.append("    double mainX=limitX/").append(xzFac).append(", mainY=limitY/").append(yFac).append(", mainZ=limitZ/").append(xzFac).append(";\n");
+        src.append("    double limitSmear=").append(yMul).append("*").append(smear).append(", mainSmear=limitSmear/").append(yFac).append(";\n");
+        src.append("    double bmin=0.0,bmax=0.0,mnv=0.0,pw=1.0;\n");
+        src.append("    for(int i=0;i<8;i++){ if(").append(fn).append("_main_present[i]){ __constant int* pp=").append(fn).append("_main_perm+i*256;\n");
+        src.append("        mnv+=mc_perlin5(pp, mc_wrap(mainX*pw), mc_wrap(mainY*pw), mc_wrap(mainZ*pw), ")
+           .append(fn).append("_main_off[i*3],").append(fn).append("_main_off[i*3+1],").append(fn).append("_main_off[i*3+2], mainSmear*pw, mainY*pw)/pw; } pw/=2.0; }\n");
+        src.append("    double factor=(mnv/10.0+1.0)/2.0; int isMax=factor>=1.0, isMin=factor<=0.0; pw=1.0;\n");
+        src.append("    for(int i=0;i<16;i++){ double wx=mc_wrap(limitX*pw),wy=mc_wrap(limitY*pw),wz=mc_wrap(limitZ*pw),ysp=limitSmear*pw;\n");
+        src.append("        if(!isMax && ").append(fn).append("_min_present[i]){ __constant int* pp=").append(fn).append("_min_perm+i*256;\n");
+        src.append("            bmin+=mc_perlin5(pp,wx,wy,wz,").append(fn).append("_min_off[i*3],").append(fn).append("_min_off[i*3+1],").append(fn).append("_min_off[i*3+2], ysp, limitY*pw)/pw; }\n");
+        src.append("        if(!isMin && ").append(fn).append("_max_present[i]){ __constant int* pp=").append(fn).append("_max_perm+i*256;\n");
+        src.append("            bmax+=mc_perlin5(pp,wx,wy,wz,").append(fn).append("_max_off[i*3],").append(fn).append("_max_off[i*3+1],").append(fn).append("_max_off[i*3+2], ysp, limitY*pw)/pw; }\n");
+        src.append("        pw/=2.0; }\n");
+        src.append("    return mc_clampedLerp(factor, bmin/512.0, bmax/512.0)/128.0;\n}\n");
+    }
+
+    // getOctaveNoise(i) = noiseLevels[len-1-i] (REVERSED). Emits perm/off/present arrays for maxOct octaves.
+    private void emitBlendedTables(String prefix, PerlinNoise pn, int maxOct) {
+        ImprovedNoise[] levels = pn.canvas$getNoiseLevels();
+        int len = levels.length;
+        int[] perm = new int[maxOct * 256];
+        double[] off = new double[maxOct * 3];
+        int[] present = new int[maxOct];
+        for (int i = 0; i < maxOct; i++) {
+            int idx = len - 1 - i;
+            if (idx >= 0 && idx < len && levels[idx] != null) {
+                present[i] = 1;
+                byte[] pt = levels[idx].getPermTable();
+                for (int j = 0; j < 256; j++) perm[i*256+j] = pt[j] & 0xFF;
+                off[i*3] = levels[idx].xo; off[i*3+1] = levels[idx].yo; off[i*3+2] = levels[idx].zo;
+            }
+        }
+        emitIntArray(prefix + "_perm", perm);
+        emitDoubleArray(prefix + "_off", off);
+        emitIntArray(prefix + "_present", present);
+    }
+
+    private void emitPerlinLoop(String varName, String octArr, String permArr, int num,
+                                String cx, String cy, String cz) {
+        src.append("    double ").append(varName).append("=0.0;\n");
+        src.append("    double ").append(varName).append("_x=").append(cx)
+           .append(", ").append(varName).append("_y=").append(cy)
+           .append(", ").append(varName).append("_z=").append(cz).append(";\n");
+        src.append("    for(int i=0;i<").append(num).append(";i++){\n");
+        src.append("        double amp=").append(octArr).append("[i*6+4]; if(amp==0.0) continue;\n");
+        src.append("        double freq=").append(octArr).append("[i*6+3];\n");
+        src.append("        double vf=").append(octArr).append("[i*6+5];\n");
+        src.append("        __constant int* pp=").append(permArr).append("+i*256;\n");
+        src.append("        double g=mc_perlin(pp, mc_wrap(").append(varName).append("_x*freq), mc_wrap(")
+           .append(varName).append("_y*freq), mc_wrap(").append(varName).append("_z*freq), ")
+           .append(octArr).append("[i*6+0],").append(octArr).append("[i*6+1],").append(octArr).append("[i*6+2]);\n");
+        src.append("        ").append(varName).append("+=amp*g*vf;\n    }\n");
+    }
+
+    private void emitDoubleArray(String name, double[] arr) {
+        src.append("__constant double ").append(name).append('[').append(arr.length).append("]={");
+        for (int i = 0; i < arr.length; i++) { if (i>0) src.append(','); src.append(hexD(arr[i])); }
+        src.append("};\n");
+    }
+
+    private void emitIntArray(String name, int[] arr) {
+        src.append("__constant int ").append(name).append('[').append(arr.length).append("]={");
+        for (int i = 0; i < arr.length; i++) { if (i>0) src.append(','); src.append(arr[i]); }
+        src.append("};\n");
+    }
+
+    // ─── Helpers ─────────────────────────────────────────────────────────────────
+
+    // Layout per octave (6 doubles): [xo, yo, zo, freq, amp, vf]. inputScale is NOT folded here
+    // (Java applies INPUT_FACTOR to the coordinate, not the frequency) and vf/amp are kept
+    // separate so the loop computes amp*g*vf in Java's exact left-assoc order.
+    private static double[] buildOctParams(PerlinNoise pn) {
+        ImprovedNoise[] levels = pn.canvas$getNoiseLevels();
+        double[] amps = pn.canvas$getAmplitudesArray();
+        double freq0 = pn.canvas$getLowestFreqInputFactor();
+        double vf0   = pn.canvas$getLowestFreqValueFactor();
+        int n = levels.length;
+        double[] p = new double[n * 6];
+        double freq = freq0, vf = vf0;
+        for (int i = 0; i < n; i++) {
+            ImprovedNoise lvl = levels[i];
+            if (lvl != null && i < amps.length && amps[i] != 0.0) {
+                p[i*6]=lvl.xo; p[i*6+1]=lvl.yo; p[i*6+2]=lvl.zo;
+                p[i*6+3]=freq; p[i*6+4]=amps[i]; p[i*6+5]=vf;
+            }
+            freq*=2.0; vf/=2.0;
+        }
+        return p;
+    }
+
+    private static int[] buildPermBuffer(PerlinNoise pn) {
+        ImprovedNoise[] levels = pn.canvas$getNoiseLevels();
+        int n = levels.length;
+        int[] buf = new int[n * 256];
+        for (int i = 0; i < n; i++) {
+            ImprovedNoise lvl = levels[i];
+            if (lvl != null) { byte[] pt = lvl.getPermTable(); for (int j=0;j<256;j++) buf[i*256+j]=pt[j]&0xFF; }
+        }
+        return buf;
+    }
+
+    private static NormalNoise asNormalNoise(DensityFunction.NoiseHolder h) {
+        return h.noise() instanceof NormalNoise nn ? nn : null;
+    }
+
+    // Wrap negatives in parens so a preceding operator never forms `--`/`*-` adjacency bugs.
+    private static String hexD(double v) {
+        if (!Double.isFinite(v)) return Double.isNaN(v) ? "0.0" : (v > 0 ? "1.0e300" : "(-1.0e300)");
+        String s = Double.toHexString(v);
+        return s.startsWith("-") ? "(" + s + ")" : s;
+    }
+
+    // NOT paren-wrapped: hexF is always followed by an 'f' suffix or used in array/return context.
+    private static String hexF(float v) {
+        if (!Float.isFinite(v)) return Float.isNaN(v) ? "0.0" : (v > 0 ? "1.0e30" : "-1.0e30");
+        return Float.toHexString(v);
+    }
+}
