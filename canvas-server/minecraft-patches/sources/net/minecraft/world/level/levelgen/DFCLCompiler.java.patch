+                double s98=fma(xr,s95,10.0), s99=fma(yr,s96,10.0), s100=fma(zr,s97,10.0);
+                double f101=xr*xr*xr*s98, f102=yr*yr*yr*s99, f103=zr*zr*zr*s100;
