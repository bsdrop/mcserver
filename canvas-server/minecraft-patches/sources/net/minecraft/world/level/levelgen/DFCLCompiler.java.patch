+                int a12=(v8+zi)&0xFF, a13=(v9+zi)&0xFF, a14=(v10+zi)&0xFF, a15=(v11+zi)&0xFF;
+                int a16=(v8+zi+1)&0xFF, a17=(v9+zi+1)&0xFF, a18=(v10+zi+1)&0xFF, a19=(v11+zi+1)&0xFF;
+                int g20=(p[a12]&15)<<2, g21=(p[a13]&15)<<2, g22=(p[a14]&15)<<2, g23=(p[a15]&15)<<2;
+                int g24=(p[a16]&15)<<2, g25=(p[a17]&15)<<2, g26=(p[a18]&15)<<2, g27=(p[a19]&15)<<2;
