+    /** Logs all distinct DF node classes in the tree — reveals every unsupported node in one pass. */
+    private static void logNodeClasses(DensityFunction df) {
+        java.util.TreeSet<String> classes = new java.util.TreeSet<>();
+        try {
+            df.mapAll(new DensityFunction.Visitor() {
+                @Override public DensityFunction apply(DensityFunction in) { classes.add(in.getClass().getName()); return in; }
+            });
+        } catch (Throwable ignored) {}
+        LOGGER.warn("[CanvasGPU] DF tree node classes ({}): {}", classes.size(), classes);
+    }
