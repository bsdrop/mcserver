+    private void emitFindTopSurfaceInner(String fn, DensityFunctions.CanvasFindTopSurfaceDF fts) {
+        String densityFn  = emitDF(fts.canvas$ftsInnerDensity());
+        String upperBndFn = emitDF(fts.canvas$ftsUpperBound());
+        int lb = fts.canvas$ftsLowerBound(), ch = fts.canvas$ftsCellHeight();
+        src.append("double ").append(fn).append("(double bx, double blockY, double bz) {\n");
+        src.append("    double topYf=").append(cY(upperBndFn, "0.0")).append(";\n");
+        src.append("    int topY=(int)floor(topYf/").append(ch).append(".0)*").append(ch).append(";\n");
+        src.append("    if (topY<=").append(lb).append(") return ").append(hexD((double)lb)).append(";\n");
+        src.append("    for (int y=topY; y>=").append(lb).append("; y-=").append(ch).append(") {\n");
+        src.append("        if (").append(cY(densityFn, "(double)y")).append(">0.0) return (double)y;\n    }\n");
+        src.append("    return ").append(hexD((double)lb)).append(";\n}\n");
+    }
